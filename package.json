{
  "name": "@minjun0219/configs",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "Minjun 의 공용 개발 설정 monorepo (Biome, TypeScript)",
  "repository": {
    "type": "git",
    "url": "https://github.com/minjun0219/configs.git"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --showConfig",
    "publish:dry": "pnpm -r publish --dry-run --no-git-checks",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --lockfile-only",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/cli": "^2.31.0",
    "@minjun0219/biome-config": "workspace:*",
    "@minjun0219/tsconfig": "workspace:*",
    "typescript": "^5.5.0"
  }
}
